// prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output = "../prisma/generated"
}

datasource db {
  provider = "postgresql"
}

// -------------------- ENUMS --------------------

enum TaskTier {
  S // Critical (Project, Exam Prep) - High XP
  A // Important (Coding, DSA)
  B // Maintenance (Assignment, Class)
  C // Chores (Laundry, Email)
}

enum Category {
  DEV
  ACADEMICS
  HEALTH
  LIFE
}

enum TaskType {
  DAILY    // Created for today specifically
  WEEKLY   // A template that repeats (e.g., Gym)
  BACKLOG  // The "Dump" area
}

enum FamRole {
  OWNER
  ADMIN
  MEMBER
}

enum FamInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum FamActivityType {
  MEMBER_JOINED
  MEMBER_LEFT
  GOAL_PROPOSED
  GOAL_ACTIVATED
  GOAL_COMPLETED
  ACHIEVEMENT_UNLOCKED
}

enum FamGoalStatus {
  PROPOSED
  ACTIVE
  COMPLETED
  REJECTED
}

// Base schema only for a future round — Challenges/Seasons/weighted Rankings
// are deferred, but these models exist so that round doesn't start from zero.
enum FamChallengeStatus {
  PENDING
  ACTIVE
  COMPLETED
  DECLINED
}

// -------------------- MODELS --------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  // --- Username + Password auth (links to OAuth identity) ---
  username      String?   @unique
  password      String?

  // --- Gamification Stats ---
  xp           Int       @default(0)
  level        Int       @default(1)
  coins        Int       @default(0)
  honestyScore Int       @default(100)
  
  // --- Streak Logic ---
  streakDays   Int       @default(0)
  multiplier   Float     @default(1.0)
  lastTaskDate DateTime?
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  tasks           Task[]
  dayLogs         DayLog[]
  inventory       InventoryItem[]
  accounts        Account[]
  sessions        Session[]
  famMemberships  FamMembership[]
  ownedFams       Fam[]           @relation("FamOwner")
  sentInvites     FamInvite[]     @relation("InvitedBy")
  proposedGoals   FamGoal[]       @relation("GoalProposedBy")
  goalVotes       FamGoalVote[]
  famActivities   FamActivity[]
  challengesSent     FamChallenge[] @relation("ChallengeChallenger")
  challengesReceived FamChallenge[] @relation("ChallengeOpponent")
  wonChallenges      FamChallenge[] @relation("ChallengeWinner")

  @@index([email])
  @@index([username])
}

model Task {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title        String
  description  String?
  
  // Type of mission
  type         TaskType @default(DAILY)
  
  // Difficulty & Type
  tier         TaskTier @default(C)
  category     Category @default(LIFE)
  
  // Time Management
  plannedDate      DateTime
  plannedStartTime DateTime?
  plannedEndTime   DateTime?
  deadline         DateTime? // For BACKLOG items
  scheduledDate    DateTime? // For DAILY items (Which specific day is this for?)
  
  // Weekly Logic (For Templates)
  repeatDays       String?   // Stores "0,2,4" (Sun, Tue, Thu) for Weekly templates
  templateId       String?   // For DAILY instances spawned from a WEEKLY template
  
  // Completion Status
  isCompleted      Boolean   @default(false)
  completedAt      DateTime?
  
  // Rewards Calculation
  basePoints       Int       @default(10)
  xpWorth          Int       @default(10)
  isBonus          Boolean   @default(false) // If true, gives +10 XP (for Weekly tasks done on time)
  timeBonus        Int       @default(0)
  finalPoints      Int       @default(0)
  
  // Duration & Expiry System
  deadlineTime      DateTime?  // Time of day the task expires
  allocatedDuration Int?       // Expected duration in minutes
  durationMet       Boolean    @default(false)  // Did user complete within duration?
  isExpired         Boolean    @default(false)  // Task was cut at deadline
  
  frequency         Int        @default(1)      // How many times to complete?
  completedFrequency Int       @default(0)      // How many times completed so far?
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId, isCompleted])
  @@index([plannedDate])
  @@index([templateId, scheduledDate])
}

model DayLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  date         DateTime @db.Date
  
  totalXP      Int      @default(0)
  tasksDone    Int      @default(0)
  possibleXP   Int      @default(0)  // Total XP that could have been earned
  
  // Anti-Cheat Metrics
  cTierCount   Int      @default(0)
  sTierCount   Int      @default(0)
  
  streakAtEnd  Int      @default(0)

  // Set once per day when active weekly templates are added to possibleXP
  weeklySeeded Boolean  @default(false)

  @@unique([userId, date])
  @@index([userId, date])
}

model InventoryItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  itemName  String
  quantity  Int      @default(1)
  
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Fam {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?

  ownerId     String
  owner       User     @relation("FamOwner", fields: [ownerId], references: [id])

  xp          Int      @default(0)
  level       Int      @default(1)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships  FamMembership[]
  invites      FamInvite[]
  goals        FamGoal[]
  activities   FamActivity[]
  achievements FamAchievement[]
  challengesSent     FamChallenge[] @relation("ChallengeFrom")
  challengesReceived FamChallenge[] @relation("ChallengeTo")
  dailyStats   FamDailyStat[]

  @@index([ownerId])
}

model FamMembership {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  famId    String
  fam      Fam      @relation(fields: [famId], references: [id], onDelete: Cascade)

  role     FamRole  @default(MEMBER)
  joinedAt DateTime @default(now())

  @@unique([userId, famId])
  @@index([famId])
}

model FamInvite {
  id              String          @id @default(cuid())
  famId           String
  fam             Fam             @relation(fields: [famId], references: [id], onDelete: Cascade)

  invitedUserId   String?
  invitedUsername String?

  invitedById     String
  invitedBy       User            @relation("InvitedBy", fields: [invitedById], references: [id])

  status          FamInviteStatus @default(PENDING)
  code            String          @unique @default(cuid())
  expiresAt       DateTime
  createdAt       DateTime        @default(now())

  @@index([famId])
  @@index([invitedUserId])
  @@index([code])
}

model FamGoal {
  id             String        @id @default(cuid())
  famId          String
  fam            Fam           @relation(fields: [famId], references: [id], onDelete: Cascade)

  proposedById   String
  proposedBy     User          @relation("GoalProposedBy", fields: [proposedById], references: [id])

  description    String
  targetValue    Int
  currentValue   Int           @default(0)
  status         FamGoalStatus @default(PROPOSED)

  createdAt      DateTime      @default(now())
  activatedAt    DateTime?
  completedAt    DateTime?

  votes          FamGoalVote[]

  @@index([famId, status])
}

model FamGoalVote {
  id       String  @id @default(cuid())
  goalId   String
  goal     FamGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  approve  Boolean

  createdAt DateTime @default(now())

  @@unique([goalId, userId])
}

model FamAchievement {
  id         String   @id @default(cuid())
  famId      String
  fam        Fam      @relation(fields: [famId], references: [id], onDelete: Cascade)
  key        String
  unlockedAt DateTime @default(now())

  @@unique([famId, key])
}

model FamActivity {
  id        String          @id @default(cuid())
  famId     String
  fam       Fam             @relation(fields: [famId], references: [id], onDelete: Cascade)
  type      FamActivityType
  actorId   String?
  actor     User?           @relation(fields: [actorId], references: [id], onDelete: SetNull)
  message   String
  createdAt DateTime        @default(now())

  @@index([famId, createdAt])
}

// --- Base schema for a future round (Challenges/Seasons/weighted Rankings).
// No API routes or UI yet — these models just mean that work doesn't start
// from an empty schema. ---

model FamChallenge {
  id            String              @id @default(cuid())
  famId         String
  fam           Fam                 @relation("ChallengeFrom", fields: [famId], references: [id], onDelete: Cascade)
  opponentFamId String?
  opponentFam   Fam?                @relation("ChallengeTo", fields: [opponentFamId], references: [id], onDelete: Cascade)

  challengerId  String
  challenger    User                @relation("ChallengeChallenger", fields: [challengerId], references: [id])
  opponentId    String?
  opponent      User?               @relation("ChallengeOpponent", fields: [opponentId], references: [id])

  metric        String
  target        Int
  status        FamChallengeStatus  @default(PENDING)
  winnerId      String?
  winner        User?               @relation("ChallengeWinner", fields: [winnerId], references: [id])

  createdAt     DateTime            @default(now())
  resolvedAt    DateTime?

  @@index([famId])
}

model FamSeason {
  id        String   @id @default(cuid())
  label     String
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())
}

// Per-Fam per-day rollup — future base for Analytics charts and a weighted
// global ranking algorithm (avg momentum, consistency %, etc. over time).
model FamDailyStat {
  id       String   @id @default(cuid())
  famId    String
  fam      Fam      @relation(fields: [famId], references: [id], onDelete: Cascade)
  date     DateTime @db.Date
  totalXP  Int      @default(0)
  activeMemberCount Int @default(0)

  @@unique([famId, date])
}

// --- NextAuth Models (Required) ---

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}